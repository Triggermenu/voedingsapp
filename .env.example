# Kopieer naar .env.local en vul in. Nooit .env.local committen.

# Anthropic API key (voor menuscan endpoint)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase — voor rate limiting op de menuscan (12 scans/uur per IP)
# Maak het project aan in een EU-regio (Frankfurt) — zie RISKS.md R-007
# Project Settings → API. De service role key NOOIT client-side gebruiken.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sentry DSN (uit sentry.io → project settings)
VITE_SENTRY_DSN=https://...@....ingest.sentry.io/...

# Analytics: geen env var nodig. Vercel Analytics + Speed Insights worden
# automatisch geactiveerd voor Vercel-deployments via @vercel/analytics +
# @vercel/speed-insights componenten in src/main.tsx.

# Schema versie (verander bij CLAUDE.md-updates)
VITE_SCHEMA_VERSION=1.0.0
